# IMPORTANT (Windows path rules)
# - BASE_DIR MUST use forward slashes, even on Windows.
#   Example: C:/Users/you/Docker Stuff (NOT C:\\Users\\you\\Docker Stuff)
# - The BAT writes concrete values and also normalizes slashes.

# Absolute base directory on the Windows host (forward slashes only).
BASE_DIR=C:/DockerStuff

# Absolute stack directory (where compose.yaml + Dockerfile + custom-* live).
# BAT should set this to the generated stack folder.
STACK_DIR=C:/DockerStuff/stacks/gostream

# Single container/service name.
CONTAINER_NAME=gostream-media

# Host port bindings (BAT writes concrete values; do not leave blank):
PLEX_HOST_PORT=32400
JELLYFIN_HOST_PORT=8096

GOSTORM_HOST_PORT=8090
HEALTH_HOST_PORT=8095
METRICS_HOST_PORT=8096

# Internal GoStream metrics/control port (must not conflict with Jellyfin's internal 8096)
# - Plex stacks can keep 8096.
# - Jellyfin stacks should set this to a different internal port (BAT patches config.json).
GOSTREAM_METRICS_PORT=8097

# LinuxServer base image defaults (BAT may override for user preferences)
PUID=1000
PGID=1000
TZ=America/La_Paz
PLEX_CLAIM=
